# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env
.env.local
.env.development
.env.production
.env.qianyi

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# blog
blog-article.ts
seo-article.ts
# Email template previews
email-previews/
mitm_mcp_traffic.db

# Cron script log output
logs/

# Pool avatars are regenerated at build time (scripts/generate-avatar-pool.ts)
/public/avatars/pool/

# Local tool artifacts — never commit DB dumps, Adminer exports, or dependency snapshots
*.db
*.sqlite
admin-*.csv
outdated.txt
