{
  "name": "open-launch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bun scripts/sync-directories-links.ts && bun scripts/generate-avatar-pool.ts && next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && bun scripts/apply-pending-sql.ts",
    "db:migrate:bootstrap": "bun scripts/apply-pending-sql.ts --mark-all-applied",
    "db:migrate:pending": "bun scripts/apply-pending-sql.ts --dry-run",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev",
    "lint": "eslint .",
    "ops:backup-db": "bun scripts/ops/backup-db.ts",
    "ops:sanitize-rich-text": "bun scripts/ops/sanitize-project-rich-text.ts",
    "prepare": "npx simple-git-hooks",
    "skill:receivers:check": "bun scripts/check-skill-receivers.ts",
    "skill:receivers:smoke": "bun scripts/smoke-skill-receivers.ts",
    "start": "next start",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "update-launches": "bash ./scripts/update-launches.sh"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged --verbose",
    "commit-msg": "npx commitlint --edit $1"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{ts,tsx,mjs,cjs,js,jsx}": "eslint --fix --max-warnings=999",
    "package.json": "sort-package-json"
  },
  "prettier": {
    "importOrder": [
      "<BUILTIN_MODULES>",
      "",
      "^react/(.*)$|^react$",
      "^next/(.*)$|^next$",
      "",
      "<THIRD_PARTY_MODULES>",
      "",
      "^@/types/(.*)$",
      "^@/config/(.*)$",
      "^@/lib/(.*)$",
      "^@/hooks/(.*)$",
      "^@/db/(.*)$",
      "^@/components/ui/(.*)$",
      "^@/components/(.*)$",
      "^@/app/(.*)$",
      "",
      "^[./]"
    ],
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports",
      "prettier-plugin-tailwindcss"
    ],
    "printWidth": 100,
    "semi": false
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "@babel/runtime": "7.29.7",
    "@eslint/plugin-kit": "0.4.1",
    "ajv": "6.15.0",
    "brace-expansion": "1.1.16",
    "esbuild": "0.28.1",
    "fast-uri": "3.1.3",
    "flatted": "3.4.2",
    "js-yaml": "3.15.0",
    "kysely": "0.28.17",
    "linkify-it": "5.0.2",
    "markdown-it": "14.3.0",
    "mdast-util-to-hast": "13.2.1",
    "minimatch": "3.1.5",
    "picomatch": "4.0.5",
    "postcss": "8.5.16",
    "prismjs": "1.30.0",
    "shell-quote": "1.9.0",
    "vite": "8.1.4",
    "yaml": "2.9.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@aws-sdk/s3-request-presigner": "^3.1083.0",
    "@better-auth/core": "^1.6.23",
    "@better-auth/stripe": "^1.6.23",
    "@fuma-comment/next": "^1.5.0",
    "@fuma-comment/react": "^1.5.0",
    "@fuma-comment/server": "^1.5.0",
    "@hookform/resolvers": "^4.1.3",
    "@marsidev/react-turnstile": "^1.5.3",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "better-auth": "^1.6.23",
    "boring-avatars": "^2.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cron-parser": "^5.6.1",
    "date-fns": "^4.4.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "0.45.2",
    "embla-carousel-react": "^8.6.0",
    "emblor": "^1.4.8",
    "gray-matter": "^4.0.3",
    "input-otp": "^1.4.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.475.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "next-mdx-remote": "6.0.0",
    "next-themes": "^0.4.6",
    "node-html-markdown": "^2.0.0",
    "pg": "^8.22.0",
    "pg-copy-streams": "^7.0.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-syntax-highlighter": "^15.6.6",
    "recharts": "3.9.2",
    "rehype-sanitize": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remixicon": "^4.9.1",
    "remixicon-react": "^1.0.0",
    "resend": "^4.8.0",
    "sanitize-html": "^2.17.5",
    "satori": "^0.12.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "undici": "^7.28.0",
    "uuid": "^11.1.1",
    "vaul": "^1.1.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "simple-git-hooks": "^2.13.1",
    "sort-package-json": "^3.7.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "22.22.2"
  }
}
