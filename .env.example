# =============================================================================
# Application
# =============================================================================
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=contact@open-launch.com
NODE_ENV=development

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/open_launch

# =============================================================================
# Redis (rate limiting, sessions)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Authentication (Better Auth)
# =============================================================================
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Google OAuth (server-side)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google One-Tap (client-side)
NEXT_PUBLIC_ONE_TAP_CLIENT_ID=your_one_tap_client_id

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Cloudflare Turnstile (Anti-bot CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Admin
ADMIN_EMAIL=admin@aat.ee

# =============================================================================
# Payments (Stripe)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_PREMIUM_PAYMENT_LINK=https://buy.stripe.com/...
NEXT_PUBLIC_PREMIUM_PLUS_PAYMENT_LINK=https://buy.stripe.com/...

# =============================================================================
# Storage (Cloudflare R2)
# =============================================================================
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_DOMAIN=statics.aat.ee

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# =============================================================================
# AI (DeepSeek)
# =============================================================================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash

# =============================================================================
# Web Crawling (Crawl4AI)
# =============================================================================
CRAWL4AI_URL=https://crawl4ai.example.com
CRAWL4AI_API_TOKEN=your_crawl4ai_token

# =============================================================================
# External APIs
# =============================================================================
PRODUCTHUNT_API_KEY=your_producthunt_api_key

# Discord Notifications (webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_LAUNCH_WEBHOOK_URL=https://discord.com/api/webhooks/...

# =============================================================================
# Analytics
# =============================================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
PLAUSIBLE_API_KEY=
PLAUSIBLE_URL=
PLAUSIBLE_SITE_ID=

# =============================================================================
# Cron Jobs
# =============================================================================
CRON_API_KEY=your_cron_api_key
