# =============================================================================
# Application
# =============================================================================
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=contact@open-launch.com
NODE_ENV=development
# Test-only safety gate: blocks all non-GET/HEAD requests plus auth, cron, and
# admin paths, and adds a noindex response header. Never enable in production.
STAGING_READ_ONLY=false

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/open_launch

# =============================================================================
# Redis (rate limiting, sessions)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Authentication (Better Auth)
# =============================================================================
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Google OAuth (server-side)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google One-Tap (client-side)
NEXT_PUBLIC_ONE_TAP_CLIENT_ID=your_one_tap_client_id

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Cloudflare Turnstile (Anti-bot CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Admin
ADMIN_EMAIL=admin@aat.ee

# =============================================================================
# Payments (Stripe)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_PREMIUM_PAYMENT_LINK=https://buy.stripe.com/...
NEXT_PUBLIC_PREMIUM_PLUS_PAYMENT_LINK=https://buy.stripe.com/...

# Directory listing tiers (Phase 3). Each tier needs its own Stripe
# Payment Link. The webhook differentiates directory orders from
# premium-launch orders via a `dir_<orderId>` prefix on
# `client_reference_id`, set by the `createDirectoryOrder` action.
# All five tiers are ONE-TIME payment links ($3.99 / $6.99 / $15.99 / $19.99 /
# $25.99). A subscription-mode link for any of these is HELD by the webhook
# (fail-closed) — make sure ULTRA points at a one-time price, not the old sub.
NEXT_PUBLIC_DIRECTORY_PAYMENT_LINK_BASIC=https://buy.stripe.com/...
NEXT_PUBLIC_DIRECTORY_PAYMENT_LINK_PLUS=https://buy.stripe.com/...
NEXT_PUBLIC_DIRECTORY_PAYMENT_LINK_PRO=https://buy.stripe.com/...
NEXT_PUBLIC_DIRECTORY_PAYMENT_LINK_ULTRA=https://buy.stripe.com/...
NEXT_PUBLIC_DIRECTORY_PAYMENT_LINK_ULTRA_PLUS=https://buy.stripe.com/...

# =============================================================================
# Storage (Cloudflare R2)
# =============================================================================
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_DOMAIN=statics.aat.ee

# =============================================================================
# Database backups (cron /api/cron/db-backup, every 3 days → private S3 bucket)
# =============================================================================
# Master switch — backups only run when this is "true" (or "1"). Leave off until
# the bucket + passphrase below are set; an off switch is a clean no-op (no alert).
BACKUP_ENABLED=false
# A logical Postgres dump (gzip + AES-256-GCM encrypted) is uploaded every 3 days
# to a SEPARATE, PRIVATE S3-compatible bucket, with 30-day retention. NEVER
# reuse the public assets bucket above — a dump contains user emails, Stripe ids,
# etc. Create a private bucket + a bucket-scoped key. HTTPS is mandatory.
BACKUP_S3_BUCKET=openlaunch-backups
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_ENDPOINT=s3.example.invalid
BACKUP_S3_REGION=us-west-2
# Bootstrap only: exact encrypted object key used by the one-time restore
# service. Change it only together with a newly provisioned empty database.
RESTORE_BACKUP_SOURCE=
# Encryption passphrase: each backup's key is scrypt-derived from this with a
# per-backup random salt. The SAME passphrase encrypts and restores — store it
# safely; a lost passphrase means backups are unrecoverable. Generate once, e.g.:
#   openssl rand -base64 32
BACKUP_PASSPHRASE=

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# =============================================================================
# AI (DeepSeek)
# =============================================================================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash

# =============================================================================
# Web Crawling (Crawl4AI)
# =============================================================================
CRAWL4AI_URL=https://crawl4ai.example.com
CRAWL4AI_API_TOKEN=your_crawl4ai_token

# =============================================================================
# External APIs
# =============================================================================
PRODUCTHUNT_API_KEY=your_producthunt_api_key

# Discord Notifications (webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_LAUNCH_WEBHOOK_URL=https://discord.com/api/webhooks/...

# =============================================================================
# Analytics
# =============================================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
PLAUSIBLE_API_KEY=
PLAUSIBLE_URL=
PLAUSIBLE_SITE_ID=

# =============================================================================
# Cron Jobs
# =============================================================================
CRON_API_KEY=your_cron_api_key

# Optional external dead-man heartbeat. The dispatcher pings this URL on every
# successful run; point it at a healthchecks.io / Better Stack monitor so an
# OUTSIDE service alerts when the whole scheduler stops (the in-app cron-health
# monitor can't catch total dispatcher death — it runs on the same scheduler).
# Leave blank to disable; a missing/broken URL never affects dispatch.
CRON_HEARTBEAT_URL=

# =============================================================================
# Next.js Server Actions
# =============================================================================
# Stable encryption key for Server Action IDs. Without this, every build
# generates new hashes and any user with a stale tab hits "Failed to find
# Server Action" the first time they submit a form after deploy.
# Generate once with: openssl rand -base64 32
# Then NEVER rotate (rotation invalidates every still-open browser tab).
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# =============================================================================
# Cross-site launch syndication (Plus/Pro/Ultra → partner sites)
# =============================================================================
# After a Plus/Pro/Ultra directory order is paid, the listing is auto-posted
# to the partner sites below. The Stripe webhook enqueues one row per site in
# `launch_syndication`; the `/api/cron/syndicate-launches` worker (registered
# in cron_schedule by migration 0026) pushes each with retry/backoff and then
# marks the order `fulfilled` once all sites succeed.
#
# Shared bearer key — MUST equal EXTERNAL_LAUNCH_API_KEY set on every target
# below. Generate once with: openssl rand -hex 32
EXTERNAL_LAUNCH_API_KEY=
# Full /api/external/launch endpoint URL of each syndication target. A target
# with no URL set is safely deferred by the worker (no retry burned) until
# configured.
#
# bigkr / mf8 / hicyou are standalone partner sites (one endpoint each).
# SYNDICATION_TOOLSO_URL is a single GATEWAY in front of the toolso-ai-open
# network (mifar / qoo / fastd / xlayers / upperstory / xemvip / skachat /
# nexablocks / blackhawkgames / …): aat.ee posts once and the gateway fans out
# to its own sites, so adding toolso domains needs NO change here. For Plus
# orders aat.ee sends maxSites=5 and the gateway randomly publishes to that
# many of its sites; Pro/Ultra/Ultra Plus publish to the whole network.
SYNDICATION_BIGKR_URL=https://bigkr.com/api/external/launch
SYNDICATION_MF8_URL=https://mf8.biz/api/external/launch
SYNDICATION_HICYOU_URL=https://hicyou.com/api/external/launch
SYNDICATION_TOOLSO_URL=https://mifar.net/api/external/launch
# Optional: per-target key override (defaults to EXTERNAL_LAUNCH_API_KEY above).
# One per target: SYNDICATION_<SITE>_API_KEY — SITE ∈ BIGKR / MF8 / HICYOU /
# TOOLSO (e.g. SYNDICATION_TOOLSO_API_KEY=).
